{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "ppe-platform",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["hnd1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://ppe-alpha.vercel.app",
    "NEXT_PUBLIC_APP_NAME": "MDLooker",
    "NEXT_PUBLIC_APP_VERSION": "1.0.0"
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    }
  ],
  "redirects": [
    {
      "source": "/old-search",
      "destination": "/ppe/products",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/ppe/products",
      "permanent": true
    },
    {
      "source": "/companies",
      "destination": "/ppe/manufacturers",
      "permanent": true
    },
    {
      "source": "/products",
      "destination": "/ppe/products",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-data",
      "schedule": "0 2 * * *"
    }
  ]
}
