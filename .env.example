# MDLooker v6.0 环境变量配置示例
# 复制此文件为 .env.production 并填入实际值

# ============================================
# 数据库配置 (Supabase)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# FDA API 配置
# ============================================
# 注意：请从 FDA 官网申请 API 密钥：https://api.fda.gov/
FDA_API_KEY=your-fda-api-key-here

# ============================================
# 监控与告警 - Sentry
# ============================================
# Sentry DSN (从 https://sentry.io 获取)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=mdlooker

# ============================================
# 通知配置 (可选)
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ============================================
# AI 服务 - 火山引擎 (推荐使用)
# ============================================
# 火山引擎 API 配置
VOLCANO_API_KEY=your-volcano-api-key-here
VOLCANO_API_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山方舟大模型 API 密钥 (用于 AI 搜索和对话)
VOLCENGINE_ARK_API_KEY=your-volcengine-ark-api-key-here

# 火山方舟大模型 ID 或 Endpoint ID (可选，默认自动选择可用模型)
# 可填写 Model ID (如 doubao-1.5-pro-32k-250115) 或 Endpoint ID (如 ep-xxxxx)
VOLCENGINE_ARK_MODEL=
VOLCENGINE_ARK_ENDPOINT_ID=

# 阿里云百炼模型配置（备用）
# 可选：qwen-max, qwen-plus, qwen-turbo
ALIBABA_BAILIAN_API_KEY=your-alibaba-api-key-here
ALIBABA_BAILIAN_MODEL=qwen-max

# ============================================
# 翻译服务 - 百度翻译
# ============================================
BAIDU_TRANSLATE_APP_ID=your-baidu-app-id
BAIDU_TRANSLATE_SECRET_KEY=your-baidu-secret-key

# 百度翻译 API 地址
BAIDU_TRANSLATE_API_URL=https://fanyi-api.baidu.com/api/translate/v2

# ============================================
# 搜索服务 - 百度 AI 搜索
# ============================================
BAIDU_AI_SEARCH_KEY=your-baidu-ai-search-key
BAIDU_AI_SEARCH_URL=https://openapi.baidu.com/rest/2.0/ai_search/v1/search

# ============================================
# 向量数据库 (可选，用于本地向量搜索)
# ============================================
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ============================================
# 医疗合规服务 - Medplum
# ============================================
# Medplum API 配置
MEDPLUM_BASE_URL=https://api.medplum.com
MEDPLUM_CLIENT_ID=your-medplum-client-id
MEDPLUM_CLIENT_SECRET=your-medplum-client-secret

# Medplum 功能开关
MEDPLUM_ENABLED=true
MEDPLUM_SEARCH_ENABLED=true
MEDPLUM_ALERTS_ENABLED=true
MEDPLUM_REGULATORY_ENABLED=true

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=https://mdlooker.com
NEXT_PUBLIC_APP_NAME=MDLooker
NEXT_PUBLIC_APP_VERSION=6.0.0

# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=en

# 支持的语言列表
NEXT_PUBLIC_LOCALES=en,zh-CN

# ============================================
# 商务工具 API
# ============================================

# 汇率 API (可选)
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# 海关编码查询 API (可选)
HS_CODE_API_KEY=
HS_CODE_API_URL=

# 船期查询 API (可选)
SHIPPING_API_KEY=
SHIPPING_API_URL=

# ============================================
# 监控与分析 (可选)
# ============================================

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Sentry (错误监控)
SENTRY_DSN=

# ============================================
# 安全配置
# ============================================

# JWT 密钥
JWT_SECRET=your-jwt-secret-change-this-in-production

# API 限流 (每分钟请求数)
API_RATE_LIMIT=100

# ============================================
# 开发环境特定配置
# ============================================

# 开发模式
NODE_ENV=development

# 调试模式
DEBUG=false

# ============================================
# 生产环境特定配置
# ============================================

# 生产环境请取消以下注释
# NODE_ENV=production
# DEBUG=false
